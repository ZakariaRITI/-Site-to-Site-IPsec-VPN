hostname ISP
! ISP Router - Transit router simulating the untrusted network
! Routes traffic between Site-A and Site-B but does not participate in VPN

!===============================
! Interface Configuration
!===============================
interface Serial0/3/0
 ip address 203.0.113.1 255.255.255.252
 clock rate 2000000
! Connects to Site-A

interface Serial0/3/1
 ip address 192.0.2.1 255.255.255.252
 clock rate 2000000
! Connects to Site-B

!===============================
! Routing Configuration
!===============================
router ospf 1
 router-id 3.3.3.3
 network 203.0.113.0 0.0.0.3 area 0
 network 192.0.2.0 0.0.0.3 area 0
! OSPF ensures connectivity between Site-A and Site-B LANs
